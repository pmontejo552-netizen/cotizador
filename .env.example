# --- Base de datos ---
# SQLite local (por defecto). Para Postgres, cambiá el provider en prisma/schema.prisma
# y poné aquí la URL de conexión (postgresql://...).
DATABASE_URL="file:./dev.db"

# --- API de Claude (Anthropic) ---
# OBLIGATORIA para: leer Excel de precios, precios estimados y el botón "Revisar".
# Conseguí tu key en https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."

# Modelo de Claude a usar (string vigente). Confirmá en https://docs.claude.com
ANTHROPIC_MODEL="claude-sonnet-4-6"

# --- Almacenamiento de archivos ---
# Carpeta donde se guardan Excel y adjuntos subidos. En Render/Railway, apuntá
# esto a un disco persistente montado (ej. /data/uploads).
UPLOAD_DIR="./uploads"

# --- Autenticación (nivel 2) ---
# Clave para firmar las sesiones (JWT). OBLIGATORIA en producción. Usá una cadena
# larga y aleatoria (ej. `openssl rand -base64 48`).
SESSION_SECRET="cambia-esto-por-una-cadena-larga-y-aleatoria"

# Primer administrador. Si todavía no hay ningún usuario, el primer login con estas
# credenciales crea el admin (o corré `npm run seed:admin`). Cambiá la contraseña al entrar.
ADMIN_EMAIL="admin@tuempresa.com"
ADMIN_PASSWORD="poné-una-contraseña-fuerte"
ADMIN_NAME="Administrador"
